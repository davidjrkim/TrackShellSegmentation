{
  "family": "trackshell-segmentation",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "8192",
  "executionRoleArn": "arn:aws:iam::780142024893:role/trackshell-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::780142024893:role/trackshell-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "trackshell-segmentation",
      "image": "780142024893.dkr.ecr.ap-northeast-2.amazonaws.com/trackshell-segmentation:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8001,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:780142024893:parameter/trackshell/database-url"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:780142024893:parameter/trackshell/aws-access-key-id"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:780142024893:parameter/trackshell/aws-secret-access-key"
        },
        {
          "name": "GEMINI_API_KEY",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:780142024893:parameter/trackshell/gemini-api-key"
        },
        {
          "name": "MAPBOX_TOKEN",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:780142024893:parameter/trackshell/mapbox-token"
        },
        {
          "name": "MODEL_CHECKPOINT_KEY",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:780142024893:parameter/trackshell/model-checkpoint-key"
        },
        {
          "name": "S3_CHECKPOINT_BUCKET",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:780142024893:parameter/trackshell/s3-checkpoint-bucket"
        }
      ],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "ap-northeast-2"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/trackshell-segmentation",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:8001/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
